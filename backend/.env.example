# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/education_space

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin seed
FIRST_ADMIN_EMAIL=admin@educationspace.com
FIRST_ADMIN_PASSWORD=admin123

# Telegram
BOT_TOKEN=your-telegram-bot-token
CHAT_ID=your-telegram-chat-id

# App
APP_ENV=development
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
